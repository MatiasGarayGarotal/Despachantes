# =============================================================
# .env.example — DespachantesV2
# Copiar a .env y completar con valores reales.
# NUNCA commitear el .env al repositorio.
# =============================================================

# Docker Compose
COMPOSE_PROJECT_NAME=despachantes

# ─── App Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=despachantes_db
DB_USER=
DB_PASS=

# ─── File Storage (MinIO local → Cloudflare R2 en producción) ─
STORAGE_ENDPOINT=http://localhost:9010
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=despachantes-docs

# ─── Auth Server (Zitadel) ────────────────────────────────────
# Masterkey: exactamente 32 caracteres. Generarlo con:
#   openssl rand -base64 24
ZITADEL_MASTERKEY=
ZITADEL_DB_PASS=
ZITADEL_ADMIN_PASSWORD=
ZITADEL_ISSUER_URI=http://localhost:8080

# Zitadel Management API — para gestionar usuarios internos desde el backend.
# 1. Crear un Machine User en Zitadel → Service Accounts → New Service Account
# 2. Generar un Personal Access Token (PAT) para ese Machine User
# 3. Asignarle el rol "Org User Manager" en la organización
# 4. Copiar el PAT en ZITADEL_MACHINE_TOKEN_DESIGN
# 5. Copiar el Org ID y el Project ID desde la consola de Zitadel
ZITADEL_MACHINE_TOKEN_DESIGN=
ZITADEL_ORG_ID=
ZITADEL_PROJECT_ID=

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Email (Resend) ───────────────────────────────────────────
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Requiere dominio verificado en Resend. En dev usar: onboarding@resend.dev
MAIL_FROM_ADDRESS=notificaciones@truman.uy

# ─── App ──────────────────────────────────────────────────────
APP_PORT=8081
