# Variables de entorno del frontend (Vite).
# Copiar a frontend/.env y completar.
# TODAS las variables deben empezar con VITE_ para que Vite las exponga.

# URL base de la API del backend
VITE_API_URL=http://localhost:8081/api/v1

# Zitadel — obtenés estos valores en http://localhost:8080/ui/console
# después de crear el Proyecto y la Aplicación (ver README de setup)
VITE_ZITADEL_AUTHORITY=http://localhost:8080
VITE_ZITADEL_CLIENT_ID=
